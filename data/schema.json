{
  "$defs": {
    "data": {
      "not": {
        "allOf": [
          { "$ref": "#" },
          { "not": { "$ref": "#/$defs/polymake" } }
        ]
      },
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "string"
        },
        {
          "patternProperties": {
            "^[a-zA-Z0-9_]*": {
              "$ref": "#/$defs/data"
            }
          },
          "type": "object",
          "not": { "required": [ "_ns" ] }
        },
        {
          "items": {
            "$ref": "#/$defs/data"
          },
          "type": "array"
        },
        {
          "$ref": "#/$defs/polymake"
        },
        {
          "type": "null"
        }
      ]
    },
    "polymake": {
      "$ref": "https://polymake.org/schemas/data.json"
    },
    "type": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "properties": {
            "name": {
              "type": "string"
            },
            "params": {
              "$ref": "#/$defs/params"
            }
          },
          "required": [
            "name"
          ],
          "type": "object"
        }
      ]
    },
    "params": {
      "anyOf": [
        {
          "$ref": "#/$defs/type"
        },
        {
          "$ref": "#"
        },
        {
          "items": {
            "$ref": "#/$defs/params"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/params"
          },
          "type": "object"
        },
        {
          "$ref": "#/$defs/data"
        }
      ]
    }
  },
  "$id": "https://oscar-system.org/schemas/mrdi.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "_ns": {
      "type": "object"
    },
    "_refs": {
      "patternProperties": {
        "^[0-9a-fA-F]{8}-([0-9a-fA-F]{4}-){3}[0-9a-fA-F]{12}$": {
          "$ref": "#"
        }
      },
      "type": "object"
    },
    "_type": {
      "$ref": "#/$defs/type"
    },
    "data": {
      "$ref": "#/$defs/data"
    }
  },
  "required": [
    "_type"
  ],
  "type": "object"
}
